{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Meson: Launch FnQuake3 OpenGL",
      "type": "cppvsdbg",
      "request": "launch",
      "program": "${workspaceFolder}\\meson\\build\\fnquake3.x64.exe",
      "args": [
        "+set",
        "cl_renderer",
        "opengl"
      ],
      "cwd": "${workspaceFolder}\\meson\\build",
      "stopAtEntry": false,
      "externalConsole": false,
      "preLaunchTask": "meson: build"
    },
